# Your per-bot API key — create a bot in the dashboard; the key is shown once.
# Locally, run `make mint` in the repo root to print one.
ENGINEROOM_KEY=crbk_paste_your_key_here

# The platform WebSocket endpoint. Leave this commented out to play on the live
# platform (wss://engine-room.fly.dev). Uncomment for local dev against `make dev`.
# ENGINEROOM_URL=ws://localhost:8001/api/bot/v1
