#!/usr/bin/env bash
# Fast local gate — mirrors the cheap CI jobs so a push never lands red.
# Only no-infra checks (integration/e2e stay CI-only). Bypass once with:
#   git push --no-verify
set -euo pipefail
repo_root="$(git rev-parse --show-toplevel)"

echo "pre-push ▸ backend: ruff + unit tests"
( cd "$repo_root/server" && uv run ruff check . && uv run pytest tests/unit -q )

echo "pre-push ▸ sdk: ruff + unit tests"
( cd "$repo_root/sdk/chessroom" && uv run ruff check . && uv run pytest -q )

echo "pre-push ▸ frontend: svelte-check"
( cd "$repo_root/frontend" && npm run check )

echo "pre-push ▸ all fast checks passed"
